# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Ollama (local mode — leave GROQ_API_KEY blank to use this) ────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2          # or llama3.1, mistral, gemma2, etc.
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Groq (cloud mode — set this to deploy without Ollama) ─────────────────────
# When GROQ_API_KEY is set, the app uses Groq's hosted Llama models + in-process
# sentence-transformers embeddings. No Ollama needed → deployable to any host.
# Free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Storage paths ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/vectordb
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./outputs

# ── Web search API keys (optional) ───────────────────────────────────────────
# Leave blank to use DuckDuckGo (free, no key, rate-limited).
# Set one of the below for more reliable search results.

# Tavily — recommended (1,000 free searches/month)
# Sign up: https://app.tavily.com
TAVILY_API_KEY=

# Brave Search (2,000 free searches/month)
# Sign up: https://brave.com/search/api/
BRAVE_API_KEY=

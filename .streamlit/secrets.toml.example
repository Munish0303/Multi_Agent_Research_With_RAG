# Copy this file's contents into the "Secrets" box in Streamlit Community Cloud
# (App → Settings → Secrets). Do NOT commit a real secrets.toml to git.
#
# Streamlit automatically exposes these as environment variables, so the app's
# config.settings (which reads os.getenv) picks them up with no extra code.

GROQ_API_KEY = "gsk_your_groq_key_here"
GROQ_MODEL = "llama-3.1-8b-instant"

# Optional — better web search than the default DuckDuckGo
# TAVILY_API_KEY = "tvly_your_key_here"

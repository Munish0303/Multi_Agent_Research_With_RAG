# ── Vercel front-end environment variables ────────────────────────────────────
# Copy to .env.local for local dev:  cp .env.example .env.local
# On Vercel, set these under: Project → Settings → Environment Variables

# Groq API key — REQUIRED unless every visitor supplies their own key in the UI.
# Free key: https://console.groq.com/keys
GROQ_API_KEY=

# Default chat model. Options:
#   llama-3.1-8b-instant     (fast, 500k tokens/day free — recommended default)
#   llama-3.3-70b-versatile  (higher quality, 100k tokens/day free, slower)
GROQ_MODEL=llama-3.1-8b-instant

# Tavily web-search key (optional). If set, the Researcher does real web search
# and the report gets real source citations. Free tier: 1,000 searches/month.
# Sign up: https://app.tavily.com
TAVILY_API_KEY=
